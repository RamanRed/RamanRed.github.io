# .gitignore for portfolio website

# Environment secrets — NEVER commit
.env.local
.env*.local
.env.production

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/

# Vercel
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS generated files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
