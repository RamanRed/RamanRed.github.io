# Environment Variables — Portfolio Website
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to version control

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional: Personal Access Token (read:public_repo scope only)
# Increases rate limit from 60 to 5000 requests/hour
GITHUB_PAT=

# ── Contact Form ──────────────────────────────────────────────────────────────
# Resend API key — get one free at https://resend.com
RESEND_API_KEY=

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=you@example.com

# ── Resume PDF ────────────────────────────────────────────────────────────────
# Vercel Blob URL of your uploaded resume
# Run: npx vercel blob upload resume.pdf
# Then paste the returned URL here
RESUME_BLOB_URL=

# Display filename for the downloaded PDF
RESUME_FILENAME=Resume.pdf

# ── Rate Limiting (optional) ──────────────────────────────────────────────────
# Upstash Redis URL and token (for persistent rate limiting across instances)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
